# ── 搜索 API（二选一）──────────────────────────────────────────
# 推荐：Google Custom Search API（100次/天免费，需 Google Cloud 账号）
GOOGLE_CSE_API_KEY=your-google-api-key
GOOGLE_CSE_CX=your-search-engine-id
# 备选：SerpAPI（200次/月免费，无需信用卡）
SERPAPI_KEY=your-serpapi-key

# ── AI API（二选一）────────────────────────────────────────────
# 推荐：OpenAI API（评分质量最高，国内用户可能需海外手机号验证）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# 备选：DeepSeek API（国内可直接注册，价格更低）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# 搜索目标市场（逗号分隔）
TARGET_MARKETS=Peru,Indonesia,Ghana,Mexico,Chile,Nigeria

# 每个关键词最多抓多少条结果
MAX_RESULTS_PER_KEYWORD=20

# 最低客户质量分（0-10）
MIN_SCORE=5

# 搜索间隔（毫秒），避免被封
SEARCH_DELAY_MS=3000

# ── 邮件发送配置 ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@company.com
SMTP_PASS=your-app-password
MAIL_FROM_NAME=Linda - MINA SC
MAIL_FROM_ADDR=your@company.com
MAIL_WHATSAPP=+8613800000000
MAIL_WEBSITE=www.example.com
MAIL_MIN_SCORE=7
MAIL_DELAY_MS=3000

# ── CSV 导出配置 ─────────────────────────────────────────────
# 导出目录（默认 ~/Desktop/矿机客户线索/）
EXPORT_DIR=~/Desktop/矿机客户线索
